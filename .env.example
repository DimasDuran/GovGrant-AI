# Qdrant (local Docker)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=user_docs

# Ollama embeddings (nomic-embed-text)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
# nomic-embed-text outputs 768-dim vectors
EMBEDDING_DIM=768

# LlamaParse (complex PDFs: tables, layout, images)
LLAMAPARSE_API_KEY=

# Default tenant for local experiments
DEFAULT_TENANT_ID=local-dev

# Dev multi-tenant auth (false = open local mode)
AUTH_ENABLED=false
# Optional: path to tenants JSON (default: data/auth/tenants.local.json or tenants.example.json)
# AUTH_REGISTRY_PATH=data/auth/tenants.local.json

# Optional: chat model for answer generation later (not required for R1 retrieve)
# OLLAMA_LLM_MODEL=llama3.2

# SBIR Topics connector (R3)
SBIR_API_BASE_URL=https://api.www.sbir.gov/public/api
SBIR_API_KEY=
SBIR_QDRANT_COLLECTION=sbir_topics
SBIR_USE_FIXTURES_ON_FAIL=true

# Anthropic chat (agent answers)
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-haiku-4-5-20251001
CHAT_MAX_TOKENS=1024
CHAT_ENABLED=true

# --- Observability: LangSmith (optional but recommended) ---
# LangGraph auto-traces when these are set. Get a key at https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=govgrant
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Observability: OpenTelemetry (optional, Grafana Cloud / OTLP) ---
# Uncomment and configure to send traces, metrics, and logs to Grafana Cloud.
# Get the endpoint and base64 token from Grafana Cloud -> OTLP details.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-grpc.<region>.grafana.net:4317
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance-id:api-key)>
# OTEL_SERVICE_NAME=govgrant
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development
